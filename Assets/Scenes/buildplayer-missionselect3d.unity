--- !u!102 &1994
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 0}
  m_GameObject: {fileID: 357}
  m_Text: "Your mission:\nBecome the supreme hunter in our clan.\n\n\nHone your tracking and hunting\nskills to lethal precision."
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 4
  m_Alignment: 1
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
  m_Font: {fileID: 12800000, guid: 2371807df2267f64c9a0717a0b0a5ec4, type: 2}
--- !u!102 &1993
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 0}
  m_GameObject: {fileID: 363}
  m_Text: "Our most prized hunting trophies are\nthe heads of human prey.\n\n\nCollecting heads unlocks new\nweapons and sharpens your skills.\n\n\nObservations indicate that these four\nhumans are most dangerous..."
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 4
  m_Alignment: 1
  m_TabSize: 4
  m_FontSize: 0
  m_FontStyle: 0
  m_Font: {fileID: 12800000, guid: 2371807df2267f64c9a0717a0b0a5ec4, type: 2}
